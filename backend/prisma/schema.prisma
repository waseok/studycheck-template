// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  userType  String   @map("user_type") // 교원, 직원, 공무직, 기간제교사 등
  position  String?  // 직위 (선택사항)
  grade     String?  // 학년 (선택사항)
  class     String?  // 반 (선택사항)
  isAdmin   Boolean  @default(false) @map("is_admin")
  role      String?  @default("USER") // SUPER_ADMIN, TRAINING_ADMIN, USER
  pinHash   String?  @map("pin_hash") // 4자리 PIN 해시
  mustSetPin Boolean @default(true) @map("must_set_pin") // PIN 설정 필요 여부
  savedSignature String? @map("saved_signature") // 저장된 서명 (base64 PNG)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  trainingParticipants TrainingParticipant[]
  signatures          TrainingSignature[]
  trainingNotices     TrainingNotice[]
  meetingParticipants MeetingParticipant[]
  meetingSignatures   MeetingSignature[]
  createdMeetings     Meeting[]
  staffGroupMembers   StaffGroupMember[]

  @@map("users")
}

model Training {
  id               String   @id @default(uuid())
  name             String   // 연수명
  description      String?  // 연수 설명 (3줄 정도)
  registrationBook String?  @map("registration_book") // 연수등록부
  cycle            String?  // 이수 주기 (1년, 학기, 3년 등)
  targetUsers      String[] @map("target_users") // 대상자 범위 (JSON 배열)
  hours            String?  // 이수시간
  implementationDate String? @map("implementation_date") // 실시일
  department       String?  // 업무부서
  manager          String   // 담당자 (필수)
  method           String?  // 연수자료 및 방법
  methodLink       String?  @map("method_link") // 연수자료 링크
  deadline         DateTime? // 이수 종료 기간
  isCompleted      Boolean  @default(false) @map("is_completed") // 취합 완료 여부
  completedAt      DateTime? @map("completed_at") // 취합 완료 시각
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  participants TrainingParticipant[]
  signatures   TrainingSignature[]

  @@map("trainings")
}

model TrainingParticipant {
  id              String    @id @default(uuid())
  trainingId      String    @map("training_id")
  userId          String    @map("user_id")
  completionNumber String?  @map("completion_number") // 이수번호
  status          String    @default("pending") // pending, completed
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trainingId, userId])
  @@map("training_participants")
}

model TrainingSignature {
  id             String   @id @default(uuid())
  trainingId     String   @map("training_id")
  userId         String   @map("user_id")
  signatureImage String   @map("signature_image") // base64 PNG
  signedAt       DateTime @default(now()) @map("signed_at")
  ipAddress      String?  @map("ip_address")

  // Relations
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trainingId, userId])
  @@map("training_signatures")
}

model Meeting {
  id          String    @id @default(uuid())
  name        String    // 회의명
  agenda      String?   // 회의 안건
  date        String?   // 일시 (텍스트)
  location    String?   // 장소
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy    User                 @relation(fields: [createdById], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]
  signatures   MeetingSignature[]

  @@map("meetings")
}

model MeetingParticipant {
  id        String   @id @default(uuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_participants")
}

model MeetingSignature {
  id             String   @id @default(uuid())
  meetingId      String   @map("meeting_id")
  userId         String   @map("user_id")
  signatureImage String   @map("signature_image")
  signedAt       DateTime @default(now()) @map("signed_at")
  ipAddress      String?  @map("ip_address")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@map("meeting_signatures")
}

model StaffGroup {
  id        String   @id @default(uuid())
  name      String   // 그룹명
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members StaffGroupMember[]

  @@map("staff_groups")
}

model StaffGroupMember {
  id      String @id @default(uuid())
  groupId String @map("group_id")
  userId  String @map("user_id")

  group StaffGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("staff_group_members")
}

model AppSettings {
  id                 String   @id @default("default")
  schoolName         String   @default("연수 관리 통합 플랫폼") @map("school_name")
  schoolLogoUrl      String?  @map("school_logo_url")
  schoolPasswordHash String?  @map("school_password_hash")
  adminPasswordHash  String?  @map("admin_password_hash")
  supabaseProjectUrl String?  @map("supabase_project_url")
  vercelAppUrl       String?  @map("vercel_app_url")
  setupCompleted     Boolean  @default(false) @map("setup_completed")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model TrainingNotice {
  id          String   @id @default(uuid())
  order       Int      // 순번
  name        String   // 연수명
  description String?  // 연수 세부 설명
  targetUsers String?  @map("target_users") // 대상자
  hours       String?  // 이수시간
  manager     String?  // 담당자
  method      String?  // 연수자료 및 방법
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("training_notices")
}

